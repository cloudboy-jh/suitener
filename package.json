{
  "name": "suitener",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "cli": "bun run packages/cli/src/index.ts",
    "dev": "bun run packages/cli/src/index.ts wrap \"bun run dev:raw\"",
    "dev:raw": "bun --watch packages/cli/src/index.ts --quiet"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
